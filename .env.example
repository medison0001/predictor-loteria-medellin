# Configuración del Predictor de Lotería de Medellín

# Configuración de Flask
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=loteria-medellin-predictor-2026

# Configuración de Base de Datos
DATABASE_URL=sqlite:///loteria_medellin.db

# Configuración de Logging
LOG_LEVEL=INFO
LOG_FILE=logs/aplicacion.log

# Configuración del Predictor
# Pesos iniciales de los métodos (deben sumar 1.0)
PESO_FRECUENCIA_HISTORICA=0.20
PESO_ANALISIS_CICLOS=0.20
PESO_PATRONES_POSICION=0.15
PESO_ANALISIS_SERIES=0.10
PESO_SUMA_DIGITOS=0.10
PESO_VECINOS_MATRICES=0.15
PESO_PATRONES_FECHA=0.10

# Configuración de Aprendizaje
AJUSTE_PREMIO=1.02           # Factor de aumento por acierto (2%)
AJUSTE_PENALIZACION=0.98     # Factor de reducción por fallo (2%)
PESO_MINIMO=0.05             # Peso mínimo por método (5%)
PESO_MAXIMO=0.35             # Peso máximo por método (35%)

# Configuración de API
MAX_RESULTADOS_HISTORIAL=100
TIMEOUT_PREDICCION=30        # segundos
CACHE_PREDICCION=300         # 5 minutos

# Rutas de archivos
RUTA_DATOS=datos/
ARCHIVO_RESULTADOS=RESULTADOS_PREMIO_MAYOR_LOTERIA_DE_MEDELLIN_20260505.csv
RUTA_LOGS=logs/
RUTA_BACKUPS=backups/